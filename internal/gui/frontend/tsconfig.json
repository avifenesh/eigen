{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["src/lib/*"],
      "$bindings/*": ["bindings/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "bindings/**/*.ts", "bindings/**/*.js"]
}
