{
  "manifest_version": 3,
  "name": "Eigen Chrome Connector",
  "version": "0.5.0",
  "description": "Connector-only bridge between Eigen MCP tools and the user's Chrome session.",
  "key": "",
  "permissions": [
    "activeTab",
    "debugger",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Eigen Chrome Connector"
  }
}
