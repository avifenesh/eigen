# GUI frontend: deps, generated bindings, and the built bundle are not source.
# A committed dist/.gitkeep keeps the go:embed directive resolvable; the real
# bundle is produced by `vite build` (Taskfile/CI) before `wails3 build`.
/internal/gui/frontend/node_modules/
/internal/gui/frontend/bindings/
/internal/gui/frontend/dist/
