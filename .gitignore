/bin/
# stray root build artifact from `go build -o eigen .`
/eigen
/dist/
/coverage.out

# local credentials/config; never commit project-local env files
.env
.env.*
!.env.example
/.eigen/

# local QA evidence can contain private session titles, paths, or screenshots
/docs/quality/

# design-system scratch mocks
.design-mock/

# GUI frontend deps + generated bindings are not source.
/internal/gui/frontend/node_modules/
/internal/gui/frontend/bindings/
# The built dist/ bundle IS committed (not ignored): the Go binary embeds it via
# go:embed, and neither `make gui-desktop` nor the gui-phase gate nor releases
# ran `vite build` first — so a clean checkout/build embedded a stale or missing
# frontend, and committed frontend fixes never reached the binary. Committing the
# bundle makes `go build` self-contained; `make gui-frontend` regenerates it when
# the Svelte source changes (run it + commit the result with frontend edits).
